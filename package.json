{
  "name": "business-tinder",
  "version": "1.0.0",
  "description": "Business Tinder — Telegram Mini App for professional networking",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate deploy",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
